{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SerialHub",
  "version": "1.0.0",
  "identifier": "io.github.wigowigo10.serialhub",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SerialHub",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "copyright": "Copyright © 2026 Higor Alexandre (WigoWigo10). All rights reserved.",
    "shortDescription": "High-performance serial monitor and terminal for embedded systems.",
    "longDescription": "SerialHub is a modern, cross-platform serial monitor designed for embedded systems engineers, featuring real-time plotting, hardware telemetry, and advanced connection management.",
    "resources": [],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": true
      }
    }
  }
}